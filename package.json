{
  "name": "beamng-content-manager",
  "version": "0.3.24",
  "description": "A comprehensive content manager for BeamNG.drive and BeamMP — manage mods, vehicles, maps, servers, and more from a single desktop app.",
  "main": "./out/main/index.js",
  "author": "Justmusa",
  "license": "GPL-3.0",
  "homepage": "https://github.com/musanajam11/BeamNG-Content-Manager",
  "repository": {
    "type": "git",
    "url": "https://github.com/musanajam11/BeamNG-Content-Manager.git"
  },
  "bugs": {
    "url": "https://github.com/musanajam11/BeamNG-Content-Manager/issues"
  },
  "keywords": [
    "beamng",
    "beammp",
    "content-manager",
    "mod-manager",
    "electron",
    "gaming"
  ],
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "electron-vite preview",
    "dev": "electron-vite dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "dev:web": "vite --config web/vite.config.ts",
    "build:web": "vite build --config web/vite.config.ts"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@iarna/toml": "^2.2.5",
    "@monaco-editor/react": "^4.7.0",
    "@tailwindcss/vite": "^4.2.2",
    "archiver": "^7.0.1",
    "country-flag-icons": "^1.6.15",
    "discord-rpc": "^4.0.1",
    "electron-updater": "^6.8.3",
    "fabric": "^6.9.1",
    "framer-motion": "^12.38.0",
    "i18next": "^26.0.3",
    "lucide-react": "^1.7.0",
    "monaco-editor": "^0.55.1",
    "pngjs": "^7.0.0",
    "react-i18next": "^17.0.2",
    "react-router-dom": "^7.14.0",
    "tailwindcss": "^4.2.2",
    "three": "^0.183.2",
    "yauzl": "^2.10.0",
    "zustand": "^5.0.12"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@types/archiver": "^7.0.0",
    "@types/node": "^22.19.1",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@types/yauzl": "^2.10.3",
    "@vitejs/plugin-react": "^5.1.1",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^5.0.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "google-translate-api-x": "^10.7.2",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "typescript": "^5.9.3",
    "vite": "^7.2.6"
  }
}
